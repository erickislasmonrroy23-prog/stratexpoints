# ── Supabase ─────────────────────────────────────────────────────────────────
# Obtén estos valores en: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=xxxxx

# ── Groq AI ───────────────────────────────────────────────────────────────────
# REQUERIDA para todos los módulos de IA (Chat, OKRGenerator, StrategicEngine,
# AIInsights, Prediction, CommandCenter Flash Insight).
# Obtén tu key gratis en: https://console.groq.com → API Keys
VITE_GROQ_API_KEY=gsk_xxxxx

# ── Super Admin ───────────────────────────────────────────────────────────────
# Código PIN para acceder al panel de SuperAdmin (si está vacío, no se usa)
VITE_SUPER_ADMIN_SECRET_CODE=

# ── Push Notifications (opcional) ─────────────────────────────────────────────
# Solo necesario si habilitas notificaciones push vía Web Push / VAPID
# Genera tus claves en: https://web-push-codelab.glitch.me
VITE_VAPID_PUBLIC_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_ENV=production
VITE_APP_NAME=Xtratia
