# ============================================================
# StratexPoints — Variables de Entorno
# Copia este archivo a .env.local y rellena los valores reales
# NUNCA subas .env.local a GitHub
# ============================================================

# ── Supabase (obligatorio) ────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Super Admin (opcional — para activación por PIN) ──────────
VITE_SUPER_ADMIN_SECRET_CODE=tu_codigo_secreto_aqui

# ── VAPID Push Notifications (opcional) ──────────────────────
# Genera con: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# ── IA / Groq (si usas la función Edge de Supabase) ───────────
# Configurar en Supabase Dashboard → Edge Functions → Secrets
# GROQ_API_KEY=gsk_...

# ── En Vercel: configurar en Project → Settings → Environment Variables
# ============================================================
